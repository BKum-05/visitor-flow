rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function hasUserRole(expectedRole) {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == expectedRole;
    }

    function inAdminCollection() {
      return signedIn()
        && exists(/databases/$(database)/documents/admin/$(request.auth.uid));
    }

    function inHostCollection() {
      return signedIn()
        && exists(/databases/$(database)/documents/host/$(request.auth.uid));
    }

    function isManagement() {
      return signedIn() && (
        hasUserRole('management')
        || hasUserRole('admin')
        || hasUserRole('guard')
        || inAdminCollection()
      );
    }

    function isHost() {
      return signedIn() && (
        hasUserRole('host')
        || inHostCollection()
      );
    }

    function canOperate() {
      return isManagement() || isHost();
    }

    function hostUnitFromProfile() {
      return (
        inHostCollection()
        && get(/databases/$(database)/documents/host/$(request.auth.uid)).data.unitNumber is string
      ) 
        ? get(/databases/$(database)/documents/host/$(request.auth.uid)).data.unitNumber
        : (
          (
            exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.unitNumber is string
          )
            ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.unitNumber
            : ""
        );
    }

    function isHostUnitLog() {
      return isHost()
        && resource.data.hostName is string
        && hostUnitFromProfile() != ""
        && resource.data.hostName == hostUnitFromProfile();
    }

    function isHostOwnLog() {
      return signedIn()
        && (
          (
            resource.data.hostOwnerUid is string
            && resource.data.hostOwnerUid == request.auth.uid
          )
          || (
            resource.data.checkedInBy is string
            && resource.data.checkedInBy == request.auth.uid
          )
          || isHostUnitLog()
        );
    }

    function validVisitorRequestCreate() {
      return request.resource.data.keys().hasOnly([
        'inviteCode',
        'visitorName',
        'hostName',
        'purpose',
        'phone',
        'expectedDate',
        'expectedClock',
        'expectedTime',
        'idNumber',
        'vehicleNo',
        'parkingRequested',
        'preferredParkingSlot',
        'status',
        'source',
        'createdAt',
        'bookingTimestamp'
      ])
      && request.resource.data.visitorName is string
      && request.resource.data.hostName is string
      && request.resource.data.purpose is string
      && request.resource.data.vehicleNo is string
      && request.resource.data.parkingRequested is bool
      && request.resource.data.status == 'pending'
      && request.resource.data.source == 'public'
      && request.resource.data.visitorName.size() > 1
      && request.resource.data.visitorName.size() <= 80
      && request.resource.data.hostName.size() > 0
      && request.resource.data.hostName.size() <= 80
      && request.resource.data.purpose.size() > 0
      && request.resource.data.purpose.size() <= 40
      && request.resource.data.vehicleNo.size() > 0
      && request.resource.data.vehicleNo.size() <= 20;
    }

    match /users/{uid} {
      allow read: if isSelf(uid) || isManagement();
      allow create, update, delete: if isSelf(uid) || isManagement();
    }

    match /admin/{uid} {
      allow read: if isSelf(uid) || isManagement();
      allow create, update, delete: if isSelf(uid) || isManagement();
    }

    match /host/{uid} {
      allow read: if isSelf(uid) || isManagement();
      allow create, update, delete: if isSelf(uid) || isManagement();
    }

    match /visitor_requests/{requestId} {
      allow create: if validVisitorRequestCreate();
      allow read, update, delete: if canOperate();
    }

    match /visitor_logs/{visitCode} {
      allow read: if isManagement() || isHost();
      allow create, update, delete: if isManagement();
    }

    match /preregistrations/{visitCode} {
      allow get: if true;
      allow list: if signedIn();
      allow create, update: if canOperate();
      allow delete: if isManagement();
    }

    match /parking_slots/{slotId} {
      allow read: if true;
      allow create, update: if canOperate();
      allow delete: if isManagement();
    }
  }
}
